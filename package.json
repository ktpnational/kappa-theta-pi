  },
  "type": "module",
  "scripts": {
    "analyze": "cross-env ANALYZE=true next build && bun report-bundle-size.js",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "bdevrs": "bunx supabase stop --no-backup && bun install && bunx supabase start && bunx supabase db reset && next dev",
    "bdevx": "bunx supabase stop && bun install && bunx supabase start && next dev",
    "build": "next build",
    "dev": "next dev --turbopack",
    "devrs": "bunx supabase stop --no-backup && bun install && bunx supabase start && bunx supabase db reset && next dev",
    "devx": "bunx supabase stop && bun install && bunx supabase start && next dev",
    "e2e:ci": "bun run e2e:install && bunx playwright test --project=chromium",
    "e2e:install": "bunx playwright install",
    "postinstall": "bunx prisma generate",
    "lint": "bunx biome check --write ./ || true && bunx stylelint src/styles/**/*.{css,scss,sass} --fix || true",
    "prisma": "bunx prisma migrate dev --name init && bunx prisma generate",
    "sb:diff": "bunx supabase db diff -f new_migration",
    "sb:link": "bunx supabase link",
    "sb:new": "bunx supabase migration new new_migration",
    "sb:pull": "bunx supabase db pull",
    "sb:push": "bunx supabase db push",
    "sb:reset": "bunx supabase db reset",
    "sb:seed": "bunx supabase db dump --data-only -f supabase/seed.sql",
    "sb:start": "bunx supabase start",
    "sb:status": "bunx supabase status",
    "sb:stop": "bunx supabase stop",
    "sb:typegen": "bunx supabase gen types typescript --local --schema public > src/types/supabase.ts",
    "sb:up": "bunx supabase migration up",
    "start": "next start",
    "test": "bunx vitest run",
    "type": "tsc --noEmit"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      "defaults",
      "not dead",
      "not IE 11",
      "not IE_Mob 11",
      "maintained node versions"
    ]
  },
