generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "next_auth"]
}

model User {
  id                      String                 @id @default(uuid())
  name                    String?
  email                   String?                @unique
  emailVerified           DateTime?              @map("email_verified")
  emailVerificationToken  String?                @unique @map("email_verification_token")
  image                   String?
  password                String?
  role                    Role                   @default(SPONSOR)
  accounts                Account[]
  sessions                Session[]
  isTwoFactorEnabled      Boolean                @default(false)
  twoFactorConfirmation   TwoFactorConfirmation?
  twoFactorConfirmationId String?
  profile                 Profile?

  @@map("users")
  @@schema("next_auth")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("next_auth")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("next_auth")
}

model VerificationToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("verification_tokens")
  @@schema("next_auth")
}

model PasswordResetToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
  @@schema("next_auth")
}

model TwoFactorToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("two_factor_tokens")
  @@schema("next_auth")
}

model TwoFactorConfirmation {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("two_factor_confirmations")
  @@schema("next_auth")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @default(SPONSOR)
  active    Boolean  @default(true)
  version   String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address Address?
  company Company?
  member  Member?

  @@map("profiles")
  @@schema("public")
}

enum Role {
  SPONSOR

  @@schema("next_auth")
}

model Address {
  id        String   @id @default(uuid())
  profileId String   @unique
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  line1     String
  line2     String?
  city      String
  province  String
  country   String
  zip       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
  @@schema("public")
}

model Member {
  id         String      @id @default(uuid())
  profileId  String      @unique
  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resumeId   String      @unique
  resume     Resume      @relation(fields: [resumeId], references: [id])
  chapterId  String
  chapter    Chapter     @relation(fields: [chapterId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  candidates Candidate[]

  @@map("members")
  @@schema("public")
}

model Resume {
  id         String   @id @default(uuid())
  member     Member?
  education  Json?
  experience Json?
  skills     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("resumes")
  @@schema("public")
}

model Company {
  id          String      @id @default(uuid())
  profileId   String      @unique
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyName String
  website     String?
  industry    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  candidates  Candidate[]

  @@map("companies")
  @@schema("public")
}

model Candidate {
  id        String          @id @default(uuid())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status    CandidateStatus @default(PENDING)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([companyId, memberId])
  @@map("candidates")
  @@schema("public")
}

model Chapter {
  id           String   @id @default(uuid())
  name         String   @unique
  greekName    String
  foundingDate DateTime
  university   String
  location     String
  status       String
  latitude     Float
  longitude    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  members      Member[]

  @@map("chapters")
  @@schema("public")
}

enum CandidateStatus {
  PENDING
  REVIEWING
  INTERVIEWED
  OFFERED
  REJECTED

  @@schema("public")
}
