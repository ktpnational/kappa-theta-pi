  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "bun run database.gen.ts",
    "analyze": "cross-env ANALYZE=true next build && bun report-bundle-size.js",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "test": "bunx vitest run",
    "type": "tsc --noEmit",
    "lint": " bunx biome check --write ./ || true && bunx stylelint src/styles/**/*.{css,scss,sass} --fix",
    "sb:start": "bunx supabase start",
    "sb:stop": "bunx supabase stop",
    "sb:reset": "bunx supabase db reset",
    "sb:push": "bunx supabase db push",
    "sb:pull": "bunx supabase db pull",
    "sb:diff": "bunx supabase db diff -f new_migration",
    "sb:new": "bunx supabase migration new new_migration",
    "sb:seed": "bunx supabase db dump --data-only -f ./src/supabase/seed.sql",
    "sb:link": "bunx supabase link",
    "sb:up": "bunx supabase migration up",
    "sb:status": "bunx supabase status",
    "check": "bun run npm-run-all --parallel check:types check:packagejson check:markdown check:spelling check:biome check:staged",
    "check:types": "bun run tsc --pretty --noEmit || true",
    "check:packagejson": "bun run npmPkgJsonLint . || true",
    "check:markdown": "bun run markdownlint '**/*.md' '.github/**/*.md' || true",
    "check:spelling": "bun run cspell . || true",
    "check:biome": "bun run npx biome check . || true",
    "check:staged": "bun run lint-staged || true",
    "fix": "contentlayer build && bun run npm-run-all --parallel fix:biome",
    "fix:biome": "bun run npx biome check . --write || true",
    "e2e:ci": "bun run e2e:install && bunx playwright test --project=chromium",
    "e2e:install": "bunx playwright install",
    "email": "bun run email dev",
    "prisma:generate": "bun run prisma generate",
    "prisma:generate:watch": "bun run prisma generate --watch",
    "prisma:migrate": "bun run prisma migrate dev --skip-seed",
    "prisma:seed": "bun run prisma db seed",
    "prisma:reset": "bun run prisma migrate reset",
    "prisma:studio": "bun run prisma studio",
    "prisma:format": "bun run prisma format",
    "commit": "bun run cz",
    "version": "bun run standard-version -t",
    "reset-hard": "bun run git clean -dfx && bun run git reset --hard && bun run npm install",
    "prepare-release": "bun run npm-run-all reset-hard version",
    "update-deps": "bun run npm-check-updates -u"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      "defaults",
      "not dead",
      "not IE 11",
      "not IE_Mob 11",
      "maintained node versions"
    ]
  },
