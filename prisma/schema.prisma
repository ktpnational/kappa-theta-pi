generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("NEXT_PUBLIC_DATABASE_URL")
  directUrl = env("NEXT_PUBLIC_DIRECT_URL")
  schemas   = ["public", "next_auth"]
}

// NextAuth.js Models (next_auth schema)
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?

  @@schema("next_auth")
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("next_auth")
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("next_auth")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("next_auth")
  @@map("verification_tokens")
}

// Application Models (public schema)
model Profile {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @default(USER)
  active    Boolean   @default(true)
  version   String?
  photoUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Related entities
  address   Address?
  member    Member?
  company   Company?

  @@schema("public")
  @@map("profiles")
}

enum Role {
  GUEST
  USER
  ADMIN
  COMPANY

  @@schema("public")
}

model Address {
  id        String   @id @default(uuid())
  profileId String   @unique
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  line1     String
  line2     String?
  city      String
  province  String
  country   String
  zip       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
  @@map("addresses")
}

model Member {
  id          String      @id @default(uuid())
  profileId   String      @unique
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resumeId    String      @unique
  resume      Resume      @relation(fields: [resumeId], references: [id])
  chapterId   String
  chapter     Chapter     @relation(fields: [chapterId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  candidates  Candidate[]

  @@schema("public")
  @@map("members")
}

model Resume {
  id         String   @id @default(uuid())
  member     Member?
  education  Json?
  experience Json?
  skills     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("public")
  @@map("resumes")
}

model Company {
  id          String      @id @default(uuid())
  profileId   String      @unique
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyName String
  website     String?
  industry    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  candidates  Candidate[]

  @@schema("public")
  @@map("companies")
}

model Candidate {
  id        String          @id @default(uuid())
  companyId String
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status    CandidateStatus @default(PENDING)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([companyId, memberId])
  @@schema("public")
  @@map("candidates")
}

model Chapter {
  id           String    @id @default(uuid())
  name         String    @unique
  greekName    String
  foundingDate DateTime
  university   String
  location     String
  status       String
  latitude     Float
  longitude    Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  members      Member[]

  @@schema("public")
  @@map("chapters")
}

enum CandidateStatus {
  PENDING
  REVIEWING
  INTERVIEWED
  OFFERED
  REJECTED

  @@schema("public")
}
